{
  "manifest_version": 3,
  "name": "Lyric Overlay Connector",
  "version": "0.1.0",
  "description": "Detects YouTube playback and sends time to the Lyric Overlay desktop app.",

  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "ws://localhost:9001/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Lyric Overlay"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:9001"
  }
}